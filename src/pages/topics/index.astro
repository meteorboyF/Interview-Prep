---
import BaseLayout from '../../layouts/BaseLayout.astro';
import topics from '../../data/generated/topics.json';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (p: string) => `${base}/${p.replace(/^\//, '')}`;
const dsa1 = topics.filter((t) => t.course === 'DSA 1').sort((a, b) => a.order - b.order);
const dsa2 = topics.filter((t) => t.course === 'DSA 2').sort((a, b) => a.order - b.order);
const dbms = topics.filter((t) => t.course === 'DBMS').sort((a, b) => a.order - b.order);
const electronics = topics.filter((t) => t.course === 'Electronics').sort((a, b) => a.order - b.order);
---

<BaseLayout title="All Topics">
  <div class="container page">
    <header class="page-head">
      <span class="tag">Study guides</span>
      <h1>All Topics</h1>
      <p class="lede">{topics.length} comprehensive guides across DSA and DBMS, with interactive visualizers and interview questions.</p>
    </header>

    <div class="progress-summary card" id="progress-summary" data-total={topics.length}>
      <div class="progress-bar"><div class="progress-fill" id="progress-fill"></div></div>
      <span id="progress-label">Loading progress…</span>
      <button class="btn" id="reset-progress" type="button">Reset</button>
    </div>

    {[
      { label: 'DSA 1 · Foundations', list: dsa1 },
      { label: 'DSA 2 · Advanced Algorithms', list: dsa2 },
      { label: 'DBMS · Databases & SQL', list: dbms },
      { label: 'Electronics · Diodes & Circuits', list: electronics },
    ].map((group) => (
      <section class="course-section">
        <h2>{group.label}</h2>
        <div class="topic-list">
          {group.list.map((t) => (
            <a class="card topic-row" href={withBase(`/topics/${t.slug}`)} data-slug={t.slug}>
              <span class="check" aria-hidden="true"></span>
              <span class="topic-num">{String(t.order).padStart(2, '0')}</span>
              <span class="topic-body">
                <span class="topic-title">{t.title}</span>
                <span class="topic-summary">{t.summary}</span>
              </span>
              {t.viz.length > 0 && <span class="viz-pill">▶ {t.viz.length}</span>}
            </a>
          ))}
          {group.label.startsWith('DBMS') && (
            <a class="card topic-row trainer-row" href={withBase('/sql-trainer/')}>
              <span class="launch" aria-hidden="true">▶</span>
              <span class="topic-num">SQL</span>
              <span class="topic-body">
                <span class="topic-title">HR SQL Trainer</span>
                <span class="topic-summary">Interactive — run real SQL in the browser against the HR dataset: 26 lessons, schema explorer and sandbox.</span>
              </span>
              <span class="viz-pill live">Interactive</span>
            </a>
          )}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>

<style>
  .page { padding: 2rem 0 1rem; }
  .page-head { text-align: center; margin-bottom: 1.5rem; }
  .page-head h1 { margin: 0.6rem 0 0.4rem; }
  .lede { color: var(--text-soft); max-width: 38rem; margin: 0 auto; }

  .progress-summary { display: flex; align-items: center; gap: 1rem; padding: 1rem 1.2rem; margin-bottom: 2rem; }
  .progress-bar { flex: 1; height: 8px; background: var(--bg-soft); border-radius: 999px; overflow: hidden; }
  .progress-fill { height: 100%; width: 0; background: linear-gradient(90deg, var(--accent), #06b6d4); transition: width 0.3s; }
  #progress-label { font-size: 0.9rem; color: var(--text-soft); font-variant-numeric: tabular-nums; white-space: nowrap; }

  .course-section { margin-bottom: 2rem; }
  .topic-list { display: flex; flex-direction: column; gap: 0.7rem; margin-top: 1rem; }
  .topic-row {
    display: flex; align-items: center; gap: 1rem; padding: 1rem 1.2rem;
    color: var(--text); transition: transform 0.1s, border-color 0.1s;
  }
  .topic-row:hover { transform: translateX(3px); text-decoration: none; border-color: var(--accent); }
  .check {
    width: 22px; height: 22px; border-radius: 50%; border: 2px solid var(--border);
    flex-shrink: 0; display: grid; place-items: center; transition: all 0.15s;
  }
  .topic-row.done .check { background: var(--success); border-color: var(--success); }
  .topic-row.done .check::after { content: '✓'; color: #fff; font-size: 0.8rem; font-weight: 800; }
  .topic-num { font-family: var(--font-mono); color: var(--text-faint); font-weight: 700; }
  .topic-body { display: flex; flex-direction: column; flex: 1; min-width: 0; }
  .topic-title { font-weight: 700; }
  .topic-summary { color: var(--text-soft); font-size: 0.88rem; }
  .viz-pill { font-size: 0.75rem; font-weight: 700; color: var(--accent); background: var(--accent-soft); padding: 0.2rem 0.55rem; border-radius: 999px; }
  .trainer-row { border-color: var(--accent); background: linear-gradient(100deg, var(--accent-soft), transparent 45%); }
  .trainer-row:hover { border-color: var(--accent); }
  .launch {
    width: 22px; height: 22px; border-radius: 50%; background: var(--accent); color: #fff;
    flex-shrink: 0; display: grid; place-items: center; font-size: 0.7rem;
  }
  .viz-pill.live { color: #fff; background: var(--accent); }
</style>

<script>
  import { initTopicListProgress } from '../../scripts/progress.ts';
  initTopicListProgress();
</script>
